{
  "name": "@awareness-sdk/memory-cloud",
  "version": "2.6.0",
  "description": "TypeScript SDK for Awareness Memory Cloud",
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "https://github.com/everest-an/Awareness-SDK.git"
  },
  "homepage": "https://awareness.market",
  "bugs": {
    "url": "https://github.com/everest-an/Awareness-SDK/issues"
  },
  "keywords": [
    "memory",
    "ai",
    "mcp",
    "vector",
    "sdk"
  ],
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "test": "npm run build && node --test tests/*.test.cjs",
    "clean": "rm -rf dist",
    "ship-gate:L1": "npm run build",
    "ship-gate:L2": "npm run test",
    "ship-gate:L3": "echo 'L3 chaos: see tests/client-chaos.test.cjs (5xx+timeout covered)'",
    "ship-gate": "npm run ship-gate:L1 && npm run ship-gate:L2 && npm run ship-gate:L3",
    "prepublishOnly": "npm run ship-gate"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "engines": {
    "node": ">=18"
  },
  "publishConfig": {
    "access": "public"
  },
  "dependencies": {
    "jszip": "^3.10.1"
  },
  "devDependencies": {
    "typescript": "^5.9.2"
  }
}
