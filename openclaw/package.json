{
  "name": "@awareness.market/openclaw-memory",
  "version": "0.6.17",
  "description": "OpenClaw plugin for Awareness memory — cross-session recall and learnings",
  "author": "Edwin Hao",
  "license": "Apache-2.0",
  "homepage": "https://awareness.market",
  "repository": {
    "type": "git",
    "url": "https://github.com/edwinhao/Awareness",
    "directory": "sdks/openclaw"
  },
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "openclaw": {
    "extensions": [
      "./dist/index.js"
    ]
  },
  "files": [
    "dist/",
    "openclaw.plugin.json",
    "README.md",
    "CHANGELOG.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsup src/index.ts --format esm,cjs --dts --clean",
    "dev": "tsup src/index.ts --format esm,cjs --dts --clean --watch",
    "test": "vitest run --exclude src/e2e.test.ts",
    "test:watch": "vitest --exclude src/e2e.test.ts",
    "test:e2e": "vitest run src/e2e.test.ts",
    "lint": "tsc --noEmit"
  },
  "peerDependencies": {
    "@modelcontextprotocol/sdk": "^1.27.0"
  },
  "devDependencies": {
    "@modelcontextprotocol/sdk": "^1.27.0",
    "@types/node": "^22.0.0",
    "tsup": "^8.0.0",
    "typescript": "^5.0.0",
    "vitest": "^4.0.0"
  },
  "publishConfig": {
    "access": "public"
  }
}
