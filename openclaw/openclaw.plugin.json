{
  "id": "openclaw-memory",
  "name": "Awareness Memory",
  "version": "0.6.17",
  "kind": "memory",
  "configSchema": {
    "type": "object",
    "properties": {
      "apiKey": {
        "type": "string",
        "default": ""
      },
      "baseUrl": {
        "type": "string",
        "default": "https://awareness.market/api/v1"
      },
      "memoryId": {
        "type": "string",
        "default": ""
      },
      "agentRole": {
        "type": "string",
        "default": "builder_agent"
      },
      "autoRecall": {
        "type": "boolean",
        "default": true
      },
      "autoCapture": {
        "type": "boolean",
        "default": true
      },
      "recallLimit": {
        "type": "integer",
        "default": 8
      },
      "captureMinTurns": {
        "type": "integer",
        "default": 0,
        "minimum": 0
      },
      "captureCategories": {
        "type": "array",
        "items": {
          "type": "string"
        },
        "default": []
      },
      "localUrl": {
        "type": "string",
        "default": "http://localhost:37800"
      },
      "embeddingLanguage": {
        "type": "string",
        "enum": [
          "english",
          "multilingual"
        ],
        "default": "english"
      }
    }
  },
  "uiHints": {
    "apiKey": {
      "label": "Awareness API Key",
      "sensitive": true
    },
    "memoryId": {
      "label": "Memory ID"
    },
    "localUrl": {
      "label": "Local Daemon URL"
    },
    "embeddingLanguage": {
      "label": "Embedding Language"
    }
  }
}
